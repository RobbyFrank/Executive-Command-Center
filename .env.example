# Copy to .env.local and set your own values.

# --- Upstash Redis (required) ---
# Tracker JSON document lives in Redis (key ecc:tracker:data). Attach from Vercel
# Storage / Marketplace or create a database at console.upstash.com. The app does
# not use a local tracker.json file.
KV_REST_API_READ_ONLY_TOKEN=
KV_REST_API_URL=
REDIS_URL=
KV_URL=
KV_REST_API_TOKEN=
#
# Vercel Blob (public image URLs for logos / avatars when set; else local public/uploads):
BLOB_READ_WRITE_TOKEN=

# Slack: Bot User OAuth Token (starts with xoxb-) for users.list, conversations.list, and the rest of the app.
# Scopes: users:read, users:read.email (optional), users.profile:read (Team import join dates via users.profile.get),
# channels:read, groups:read (for Roadmap channel picker).
SLACK_BOT_USER_OAUTH_TOKEN=
# Required for Team → Import from Slack billing filter: user OAuth token (xoxp-) for team.billableInfo only.
# Bot tokens are not allowed (not_allowed_token_type). Add User Token Scope "admin" in the Slack app, reinstall, OAuth once, then paste the user token here.
# The bot scope team.billing:read is for team.billing.info only — it does not enable team.billableInfo.
SLACK_BILLING_USER_TOKEN=

# Debug Slack join-date resolution (users.info vs users.profile.get) in the **server terminal** only — not the browser console.
# SLACK_JOIN_DATE_DEBUG=1

# Two leadership accounts (plain-text passphrases; hashed at login verify time)
AUTH_USER_1_USERNAME=robby
AUTH_USER_1_PASSWORD=your-very-long-passphrase-here-at-least-fifty-characters
AUTH_USER_2_USERNAME=nadav
AUTH_USER_2_PASSWORD=your-very-long-passphrase-here-at-least-fifty-characters

# Used to sign the session cookie (use a long random string)
SESSION_SECRET=replace-with-a-random-64-character-secret-string-for-cookie-signing

# Anthropic API key for the in-app AI assistant (dashboard). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional: override the default Claude model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
