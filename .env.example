# Copy to .env.local and set your own values.

# --- Upstash Redis (required) ---
# Tracker JSON document lives in Redis (key ecc:tracker:data). Attach from Vercel
# Storage / Marketplace or create a database at console.upstash.com. The app does
# not use a local tracker.json file.
KV_REST_API_READ_ONLY_TOKEN=
KV_REST_API_URL=
REDIS_URL=
KV_URL=
KV_REST_API_TOKEN=
#
# Vercel Blob (public image URLs for logos / avatars when set; else local public/uploads):
BLOB_READ_WRITE_TOKEN=

# Slack: Bot User OAuth Token (starts with xoxb-) for users.list and the rest of the app.
# Scopes: users:read, users:read.email (optional), users.profile:read (Team import join dates via users.profile.get).
# Roadmap channel listing: see SLACK_CHANNEL_LIST_USER_TOKEN / SLACK_BILLING_USER_TOKEN below — the bot token only sees private channels the bot joined.
SLACK_BOT_USER_OAUTH_TOKEN=
# Required for Team → Import from Slack billing filter: user OAuth token (xoxp-) for team.billableInfo only.
# Bot tokens are not allowed (not_allowed_token_type). Add User Token Scope "admin" in the Slack app, reinstall, OAuth once, then paste the user token here.
# The bot scope team.billing:read is for team.billing.info only — it does not enable team.billableInfo.
# Also used for Roadmap → Slack channel picker (conversations.list) when SLACK_CHANNEL_LIST_USER_TOKEN is unset — lists channels that user can access.
# Milestone Slack threads (Roadmap): the same user token is used for conversations.replies + chat.postMessage so you can read threads and post follow-ups as yourself
# without adding the bot to every channel. Add User Token Scopes: channels:history, groups:history, chat:write — then reinstall and re-authorize OAuth.
# New-hire onboarding-partner group DM (Team onboarding): also add User Token Scopes mpim:write (and im:write for 1:1 fallback) so conversations.open can create the [you + new hire + Nadav + onboarding partners] MPIM.
# Optional — Slack channel invites after assignment (conversations.invite): channels:write.invites + groups:write.invites. Optional — create private channel from pilot recommender (conversations.create): groups:write. Optional — AI channel suggestions use users.conversations on partners/teammates: users:read + channels:read + groups:read (see docs/environment.md).
# Team roster message-based enrichment (Import from Slack + Refresh all from Slack): add User Token Scope search:read so we can call search.messages with
# `from:<@USERID>` to infer a blank Role/Department from a person's last ~50 messages and fall back to their oldest message `ts` for a blank Join Date.
# Without search:read the app still imports/refreshes name, email, avatar, and profile join date — it just skips the AI-based role/department backfill.
SLACK_BILLING_USER_TOKEN=
# Optional: user OAuth token (xoxp-) used only for conversations.list (channel picker). Overrides SLACK_BILLING_USER_TOKEN for listing if both are set.
# Same value as SLACK_BILLING_USER_TOKEN is fine. User scopes channels:read + groups:read (or admin) so private channels you’re in appear without inviting the bot.
# When set, milestone thread status/ping also prefer this token over SLACK_BILLING_USER_TOKEN.
# SLACK_CHANNEL_LIST_USER_TOKEN=

# Debug Slack join-date resolution (users.info vs users.profile.get) in the **server terminal** only — not the browser console.
# SLACK_JOIN_DATE_DEBUG=1

# Used to sign the session cookie (use a long random string)
SESSION_SECRET=replace-with-a-random-64-character-secret-string-for-cookie-signing

# App login: each team member signs in with their work email + password. Passwords are bcrypt
# hashes stored on Person in Redis (Team → Login column for founders, or bootstrap with
# `npx tsx scripts/set-password.ts <email> <password>`). No AUTH_USER_* env vars.

# Anthropic API key for the in-app AI assistant (dashboard). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional: override the default Claude model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: Calendly (or similar) link for new-hire pilot assignment Slack messages (Team onboarding).
# ROBBY_CALENDLY_URL=

# Optional fallback for Nadav's Slack user ID (used when no roster Person id "nadav" with slackHandle exists).
# Used by the new-hire onboarding-partner group DM (conversations.open includes Nadav for accountability/oversight).
# NADAV_SLACK_USER_ID=U01234ABCDE

# --- Daily executive digest (Vercel Cron -> #executive-priorities) ---
# Channel ID (not name) of #executive-priorities. Copy from Slack: channel -> View details -> bottom of About.
# The user OAuth token (SLACK_BILLING_USER_TOKEN / SLACK_CHANNEL_LIST_USER_TOKEN) must be a member of this channel
# and hold User Token Scopes: channels:history, groups:history, chat:write.
SLACK_EXECUTIVE_PRIORITIES_CHANNEL_ID=
# Public base URL used to build hyperlinks in the digest (Roadmap deep links). Default: https://admin.mlabs.vc
# ECC_PUBLIC_BASE_URL=https://admin.mlabs.vc
# Shared secret used to authorize the Vercel Cron GET. Set the same value as the cron's Authorization: Bearer header
# (Vercel auto-injects CRON_SECRET on *.vercel.app cron invocations). Generate a long random string.
CRON_SECRET=
# Optional: when set to "1", a short failure line is posted back into the digest channel on errors.
# DIGEST_POST_FAILURES=1
